rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users – can read/write own profile only
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Marketplace – anyone can read, only authenticated can write
    match /marketplace_items/{item} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Reviews – anyone can read, only authenticated can write (once)
    match /reviews/{review} {
      allow read: if true;
      allow create: if request.auth != null && 
        !exists(/databases/$(database)/documents/reviews/$(review));
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }
    
    // Bookings – only participants can read/write
    match /bookings/{booking} {
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.customerId || 
         request.auth.uid == resource.data.providerId);
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.customerId || 
         request.auth.uid == resource.data.providerId);
    }
    
    // Default deny all others
    match /{document=**} {
      allow read, write: if false;
    }
  }
}