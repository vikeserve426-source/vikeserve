{
  "name": "VikeServe - Complete Daily Needs Super App",
  "short_name": "VikeServe",
  "description": "Book services, shop marketplace, find housing, and connect with your community",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "orientation": "portrait",
