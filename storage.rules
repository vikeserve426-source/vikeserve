rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Profile pictures - users can upload their own, anyone can read
    match /users/{userId}/profile-pictures/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Marketplace item images - public read, authenticated upload
    match /marketplace/{itemId}/images/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Property images
    match /properties/{propertyId}/images/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Booking attachments
    match /booking-attachments/{bookingId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Review photos
    match /review-photos/{bookingId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Public assets (icons, etc.)
    match /public/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    
    // Default deny for all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}